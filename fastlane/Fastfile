def current_version_line
  pubspec_contents = File.read(PUBSPEC_FILE)
  version_line = pubspec_contents.each_line.find { |line| line.start_with?("version:") }
  UI.user_error!("Missing version in #{PUBSPEC_FILE}") if version_line.nil?

  version_line
end

def current_version_name
  version_name = current_version_line.split(":", 2)[1]&.strip&.split("+", 2)&.first
  UI.user_error!("Missing version name in #{PUBSPEC_FILE}") if version_name.to_s.empty?

  version_name
end

def current_version_code
  version_code = current_version_line.split("+", 2)[1]&.strip
  UI.user_error!("Missing build number in #{PUBSPEC_FILE}") if version_code.to_s.empty?

  version_code
end

def android_connected_devices
  adb_output = sh("adb devices", log: false)

  adb_output.each_line.filter_map do |line|
    entry = line.strip
    next if entry.empty? || entry.start_with?("List of devices attached")

    serial, state = entry.split(/\s+/, 2)
    next unless state == "device"

    {
      serial: serial,
      avd_name: android_device_avd_name(serial),
      model_name: android_device_model_name(serial),
    }
  end
end

def android_device_avd_name(serial)
  return nil unless serial.start_with?("emulator-")

  avd_name = `adb -s #{Shellwords.escape(serial)} emu avd name 2>/dev/null`
    .each_line
    .map(&:strip)
    .reject(&:empty?)
    .reject { |line| line.casecmp("ok").zero? }
    .first
  return nil if avd_name.empty? || avd_name.casecmp("unknown").zero?

  avd_name
end

def android_device_model_name(serial)
  model_name = `adb -s #{Shellwords.escape(serial)} shell getprop ro.product.model 2>/dev/null`.strip
  return nil if model_name.empty?

  model_name
end

def android_connected_device_labels(connected_devices)
  connected_devices.map do |device|
    labels = [device[:serial], device[:avd_name], device[:model_name]].compact.uniq
    labels.join(" / ")
  end
end

def android_normalize_device_selector(value)
  value.to_s.strip.downcase.gsub(/[ _-]+/, " ")
end

def android_resolve_device_selector(device_selector, connected_devices)
  return nil if device_selector.empty?

  serial_match = connected_devices.find { |device| device[:serial] == device_selector }
  return serial_match[:serial] unless serial_match.nil?

  normalized_selector = android_normalize_device_selector(device_selector)

  named_matches = connected_devices.select do |device|
    [device[:avd_name], device[:model_name]].compact.any? do |candidate|
      android_normalize_device_selector(candidate) == normalized_selector
    end
  end

  if named_matches.length > 1
    UI.user_error!(
      "Configured Android screenshot device '#{device_selector}' matches multiple connected devices: #{android_connected_device_labels(named_matches).join(", ")}",
    )
  end

  named_matches.first&.dig(:serial)
end

def android_screenshot_targets(options, connected_devices)
  ANDROID_SCREENSHOT_TARGETS.each_with_object([]) do |target, targets|
    device_selector = options[target[:option_key]].to_s.strip
    device_selector = ENV[target[:env_key]].to_s.strip if device_selector.empty?
    device_selector = target[:default_device_name].to_s.strip if device_selector.empty?
    specific_device = android_resolve_device_selector(device_selector, connected_devices)

    if specific_device.nil?
      if device_selector.empty?
        if target[:required] && connected_devices.length > 1
          UI.user_error!(
            "Multiple Android devices are connected. Set #{target[:env_key]} or pass #{target[:option_key]}:<serial-or-name> for #{target[:description]} screenshots.",
          )
        end

        next unless target[:required]
      else
        UI.user_error!(
          "Configured Android screenshot device '#{device_selector}' for #{target[:description]} screenshots is not connected. Connected devices: #{android_connected_device_labels(connected_devices).join(", ")}",
        )
      end

      next
    end

    targets << target.merge(
      specific_device: specific_device,
      device_selector: device_selector.empty? ? specific_device : device_selector,
    )
  end
end

def app_store_connect_api_key_path
  File.expand_path(
    ENV["APP_STORE_CONNECT_API_KEY_PATH"] || "app-store-connect-api-key.p8",
    FASTLANE_DIR,
  )
end

def app_store_connect_api_key_file_config
  return {} unless File.exist?(APP_STORE_CONNECT_API_KEY_CONFIG)

  JSON.parse(File.read(APP_STORE_CONNECT_API_KEY_CONFIG))
rescue JSON::ParserError => error
  UI.user_error!("Invalid App Store Connect API key JSON config at #{APP_STORE_CONNECT_API_KEY_CONFIG}: #{error.message}")
end

def app_store_connect_api_key_options
  file_config = app_store_connect_api_key_file_config
  key_id = ENV["APP_STORE_CONNECT_KEY_ID"].to_s.strip
  key_id = file_config["key_id"].to_s.strip if key_id.empty?
  issuer_id = ENV["APP_STORE_CONNECT_ISSUER_ID"].to_s.strip
  issuer_id = file_config["issuer_id"].to_s.strip if issuer_id.empty?
  key_content = ENV["APP_STORE_CONNECT_API_KEY_CONTENT"].to_s.strip
  key_base64 = ENV["APP_STORE_CONNECT_API_KEY_BASE64"].to_s.strip

  key_filepath = ENV["APP_STORE_CONNECT_API_KEY_PATH"].to_s.strip
  key_filepath = file_config["key_filepath"].to_s.strip if key_filepath.empty?
  key_filepath = app_store_connect_api_key_path if key_filepath.empty?

  return nil if key_id.empty? || issuer_id.empty?

  options = {
    key_id: key_id,
    issuer_id: issuer_id,
    duration: 1200,
    in_house: false,
  }

  if !key_base64.empty?
    options[:key_content] = key_base64
    options[:is_key_content_base64] = true
  elsif !key_content.empty?
    options[:key_content] = key_content
  else
    options[:key_filepath] = File.expand_path(key_filepath, FASTLANE_DIR)
  end

  options
end

def configure_ios_build_environment
  pod_candidates = [
    "/opt/homebrew/bin/pod",
    "/usr/local/bin/pod",
  ]
  pod_path = pod_candidates.find { |candidate| File.exist?(candidate) }

  if !pod_path.nil?
    pod_bin_dir = File.dirname(pod_path)
    path_entries = ENV.fetch("PATH", "").split(":")
    ENV["PATH"] = ([pod_bin_dir] + path_entries).uniq.join(":")
  end

  ENV["LANG"] = "en_US.UTF-8"
  ENV["LC_ALL"] = "en_US.UTF-8"
end

def with_clean_ios_shell_environment
  env_keys = %w[
    BUNDLE_BIN_PATH
    BUNDLE_GEMFILE
    GEM_HOME
    GEM_PATH
    RUBYLIB
    RUBYOPT
  ]
  original_values = env_keys.to_h { |key| [key, ENV[key]] }

  env_keys.each do |key|
    ENV.delete(key)
  end

  yield
ensure
  original_values.each do |key, value|
    if value.nil?
      ENV.delete(key)
    else
      ENV[key] = value
    end
  end
end

def verify_cocoapods_available
  sh("command -v pod")
  sh("pod --version")
end

def ios_has_ui_test_target?
  return false unless File.exist?(IOS_PROJECT_FILE)

  File.read(IOS_PROJECT_FILE).include?("com.apple.product-type.bundle.ui-testing")
end

def ios_snapshot_helper_present?
  snapshot_helper_files = Dir[File.expand_path("../ios/**/*SnapshotHelper.swift", FASTLANE_DIR)]
  !snapshot_helper_files.empty?
end

def ensure_ios_screenshot_setup!(options)
  UI.user_error!("Missing iOS workspace: #{IOS_WORKSPACE}") unless File.exist?(IOS_WORKSPACE)

  unless ios_has_ui_test_target?
    UI.user_error!(
      "Missing iOS UI test target for App Store screenshots. Add a UITest target before running 'fastlane ios screenshots'.",
    )
  end

  return if ios_snapshot_helper_present? || options[:skip_snapshot_helper_check]

  UI.user_error!(
    "Missing SnapshotHelper.swift in the iOS UI tests. Add the snapshot helper before running 'fastlane ios screenshots', or pass skip_snapshot_helper_check:true if your tests already handle snapshot setup differently.",
  )
end

def ensure_ios_metadata_inputs!(options)
  metadata_path = File.expand_path(options[:metadata_path] || IOS_METADATA_DIRECTORY, PROJECT_ROOT)
  screenshots_path = File.expand_path(options[:screenshots_path] || IOS_SCREENSHOTS_DIRECTORY, PROJECT_ROOT)

  if !options[:skip_metadata] && !Dir.exist?(metadata_path)
    UI.user_error!("Missing iOS metadata directory: #{metadata_path}")
  end

  if !options[:skip_screenshots] && !Dir.exist?(screenshots_path)
    UI.user_error!("Missing iOS screenshots directory: #{screenshots_path}")
  end
end

def ios_structured_screenshot_paths(root_path)
  Dir[File.join(root_path, "*", "images", IOS_SCREENSHOT_DEVICE_DIR)]
end

def clear_ios_structured_screenshots!(root_path)
  ios_structured_screenshot_paths(root_path).each do |directory|
    FileUtils.rm_rf(directory)
  end

  report_path = File.join(root_path, "screenshots.html")
  FileUtils.rm_f(report_path)
end

def ios_collect_structured_screenshots(root_path)
  screenshots_by_language = {}

  Dir.children(root_path).sort.each do |locale|
    locale_path = File.join(root_path, locale)
    next unless File.directory?(locale_path)

    screenshot_directory = File.join(locale_path, "images", IOS_SCREENSHOT_DEVICE_DIR)
    next unless Dir.exist?(screenshot_directory)

    screenshot_files = Dir[File.join(screenshot_directory, "*.png")].sort
    next if screenshot_files.empty?

    screenshots_by_language[locale] = screenshot_files
  end

  screenshots_by_language
end

def ios_screenshot_screen_key(file_path)
  file_name = File.basename(file_path, ".png")
  match = file_name.match(/-(\d{2}-.+)$/)
  return match[1] unless match.nil?

  file_name
end

def ios_screenshot_screen_title(screen_key)
  parts = screen_key.split("-", 2)
  return screen_key.tr("-", " ") if parts.length < 2

  "#{parts[0]} #{parts[1].tr("-", " ")}"
end

def html_relative_path(pathname, from_root)
  relative_path = pathname.delete_prefix("#{from_root}/")
  relative_path.split(File::SEPARATOR).map { |segment| CGI.escape(segment).gsub("+", "%20") }.join("/")
end

def generate_ios_screenshot_report!(root_path)
  screenshots_by_language = ios_collect_structured_screenshots(root_path)
  UI.user_error!("No iOS screenshots found in #{root_path}") if screenshots_by_language.empty?

  screens = screenshots_by_language.values.flatten.each_with_object({}) do |file_path, grouped|
    screen_key = ios_screenshot_screen_key(file_path)
    grouped[screen_key] ||= []
    grouped[screen_key] << file_path
  end

  by_language_html = []
  screenshots_by_language.each do |locale, files|
    image_cells = files.each_with_index.map do |file_path, index|
      relative_path = html_relative_path(file_path, root_path)
      <<~HTML
        <td>
          <a href="./#{relative_path}" target="_blank" class="screenshotLink">
            <img class="screenshot" src="./#{relative_path}" style="width: 100%;" alt="#{CGI.escapeHTML(locale)} #{IOS_SCREENSHOT_DEVICE_DIR}" data-tab="1" data-counter="#{index + 1}">
          </a>
        </td>
      HTML
    end.join

    by_language_html << <<~HTML
      <h1 id="#{CGI.escapeHTML(locale)}" class="language">#{CGI.escapeHTML(locale)}</h1>
      <hr>
      <table>
        <tr>
          <th colspan="#{files.length}">
            <a id="#{CGI.escapeHTML(locale)}-#{IOS_SCREENSHOT_DEVICE_DIR}" class="deviceName" href="##{CGI.escapeHTML(locale)}-#{IOS_SCREENSHOT_DEVICE_DIR}">#{IOS_SCREENSHOT_DEVICE_DIR}</a>
          </th>
        </tr>
        <tr>
#{image_cells}
        </tr>
      </table>
    HTML
  end

  by_screen_html = []
  screens.sort.each do |screen_key, files|
    sorted_files = files.sort_by do |file_path|
      file_path.split(File::SEPARATOR)[-4]
    end

    image_cells = sorted_files.each_with_index.map do |file_path, index|
      relative_path = html_relative_path(file_path, root_path)
      locale = file_path.split(File::SEPARATOR)[-4]
      <<~HTML
        <td>
          <a href="./#{relative_path}" target="_blank" class="screenshotLink">
            <img class="screenshot" src="./#{relative_path}" style="width: 100%;" alt="#{CGI.escapeHTML(locale)} #{CGI.escapeHTML(ios_screenshot_screen_title(screen_key))}" data-tab="2" data-counter="#{index + 1}">
          </a>
          <div class="caption">#{CGI.escapeHTML(locale)}</div>
        </td>
      HTML
    end.join

    by_screen_html << <<~HTML
      <h2 id="#{CGI.escapeHTML(screen_key)}" class="screenName">#{CGI.escapeHTML(ios_screenshot_screen_title(screen_key))}</h2>
      <table>
        <tr>
#{image_cells}
        </tr>
      </table>
    HTML
  end

  report_html = <<~HTML
    <!DOCTYPE html>
    <html>
      <head>
        <title>fastlane/snapshot</title>
        <meta charset="UTF-8">
        <style type="text/css">
          * {
            font-family: "HelveticaNeue-Light", "Helvetica Neue Light", "Helvetica Neue", Helvetica, Arial, "Lucida Grande", sans-serif;
            font-weight: 300;
          }
          #sortMenu {
            overflow: hidden;
            border: 1px solid #ccc;
            background-color: #f1f1f1;
            display: none;
          }
          #sortMenu button {
            background-color: inherit;
            float: left;
            border: none;
            outline: none;
            cursor: pointer;
            padding: 14px 16px;
            font-size: 17px;
          }
          #sortMenu button:hover {
            background-color: #ddd;
          }
          #sortMenu button.active {
            background-color: #ccc;
          }
          .deviceName {
            display: block;
            font-size: 30px;
            padding-bottom: 24px;
            padding-top: 45px;
          }
          .screenshot {
            cursor: pointer;
            border: 1px #EEE solid;
            z-index: 0;
          }
          .caption {
            font-size: 18px;
            padding-bottom: 24px;
            padding-top: 16px;
          }
          h1, h2 {
            font-weight: bold;
          }
          th {
            text-align: left;
          }
          td {
            text-align: center;
            min-width: 200px;
            vertical-align: top;
          }
          #overlay {
            position: fixed;
            top: 0;
            left: 0;
            background: rgba(0, 0, 0, 0.8);
            z-index: 5;
            width: 100%;
            height: 100%;
            display: none;
            cursor: zoom-out;
            text-align: center;
          }
          #imageDisplay {
            height: auto;
            width: auto;
            z-index: 10;
            cursor: pointer;
          }
          #imageInfo {
            background: none repeat scroll 0 0 rgba(0, 0, 0, 0.2);
            border-radius: 5px;
            color: white;
            margin: 20px;
            padding: 10px;
            position: absolute;
            right: 0;
            top: 0;
            width: 250px;
            z-index: -1;
          }
          #imageInfo:hover {
            z-index: 20;
          }
        </style>
      </head>
      <body>
        <div id="sortMenu">
          <button id="defaultTab" class="tabLink" onclick="openTab(event, 'byLanguage')">By Language</button>
          <button class="tabLink" onclick="openTab(event, 'byScreen')">By Screen</button>
        </div>
        <div id="byLanguage" class="tabContent"><h1 class="tabTitle">By Language:</h1>
#{by_language_html.join("\n")}
        </div>
        <div id="byScreen" class="tabContent"><h1 class="tabTitle">By Screen:</h1>
#{by_screen_html.join("\n")}
        </div>
        <div id="overlay">
          <img id="imageDisplay" src="" alt="" />
          <div id="imageInfo"></div>
        </div>
        <script type="text/javascript">
          var overlay = document.getElementById('overlay');
          var imageDisplay = document.getElementById('imageDisplay');
          var imageInfo = document.getElementById('imageInfo');
          var screenshotLink = document.getElementsByClassName('screenshotLink');

          window.onload = setup();

          function setup() {
            var i, menu, tabTitles;

            menu = document.getElementById("sortMenu");
            menu.style.display = "block";

            tabTitles = document.getElementsByClassName("tabTitle");
            for (i = 0; i < tabTitles.length; i++) {
              tabTitles[i].style.display = "none";
            }

            doClick(document.getElementById("defaultTab"));
          }

          function getCurrentTab() {
            var i, tabs;
            tabs = document.getElementsByClassName("tabContent");
            for (i = 0; i < tabs.length; i++) {
              if (tabs[i].style.display != "none") {
                return i + 1;
              }
            }
            return 1;
          }

          function openTab(evt, tabName) {
            var i, tabs, tabLinks;
            tabs = document.getElementsByClassName("tabContent");
            for (i = 0; i < tabs.length; i++) {
              tabs[i].style.display = "none";
            }
            tabLinks = document.getElementsByClassName("tabLink");
            for (i = 0; i < tabLinks.length; i++) {
              tabLinks[i].className = tabLinks[i].className.replace(" active", "");
            }
            document.getElementById(tabName).style.display = "block";
            evt.currentTarget.className += " active";
          }

          function doClick(el) {
            if (document.createEvent) {
              var evObj = document.createEvent('MouseEvents', true);
              evObj.initMouseEvent("click", false, true, window, 0, 0, 0, 0, 0, false, false, false, false, 0, null);
              el.dispatchEvent(evObj);
            } else if (document.createEventObject) {
              var legacyEvent = document.createEventObject();
              el.fireEvent('onclick', legacyEvent);
            }
          }

          for (var index = 0; index < screenshotLink.length; ++index) {
            screenshotLink[index].addEventListener('click', function(e) {
              e.preventDefault();

              var img = e.target;
              if (e.target.tagName == 'A') {
                img = e.target.children[0];
              }

              var tmpImg = new Image();
              tmpImg.src = img.src;
              imageDisplay.style.height = 'auto';
              imageDisplay.style.width = 'auto';
              imageDisplay.style.paddingTop = 0;
              if (window.innerHeight < tmpImg.height) {
                imageDisplay.style.height = document.documentElement.clientHeight + 'px';
              } else if (window.innerWidth < tmpImg.width) {
                imageDisplay.style.width = document.documentElement.clientWidth + 'px';
              } else {
                imageDisplay.style.paddingTop = parseInt((window.innerHeight - tmpImg.height) / 2) + 'px';
              }

              imageDisplay.src = img.src;
              imageDisplay.alt = img.alt;
              imageDisplay.dataset.counter = img.dataset.counter;
              imageDisplay.dataset.tab = img.dataset.tab;

              imageInfo.innerHTML = '<h3>' + img.alt + '</h3>';
              imageInfo.innerHTML += decodeURI(img.src.split("/").pop());
              imageInfo.innerHTML += '<br />' + tmpImg.height + '&times;' + tmpImg.width + 'px';

              overlay.style.display = "block";
            });
          }

          imageDisplay.addEventListener('click', function(e) {
            e.stopPropagation();

            overlay.style.display = "none";

            var imgTab = parseInt(e.target.dataset.tab || getCurrentTab());
            var imgCounter = parseInt(e.target.dataset.counter) + 1;
            try {
              var link = document.body.querySelector('img[data-tab="' + imgTab + '"][data-counter="' + imgCounter + '"]').parentNode;
              doClick(link);
            } catch (error) {
              try {
                var firstLink = document.body.querySelector('img[data-tab="' + imgTab + '"][data-counter="1"]').parentNode;
                doClick(firstLink);
              } catch (ignoredError) {
                return false;
              }
            }
          });

          overlay.addEventListener('click', function() {
            overlay.style.display = "none";
          });

          function keyPressed(e) {
            e = e || window.event;
            var charCode = e.keyCode || e.which;
            switch (charCode) {
              case 27:
                overlay.style.display = "none";
                break;
              case 34:
              case 39:
              case 54:
              case 76:
              case 102:
                e.preventDefault();
                doClick(imageDisplay);
                break;
              case 33:
              case 37:
              case 52:
              case 72:
              case 100:
                e.preventDefault();
                imageDisplay.dataset.counter = parseInt(imageDisplay.dataset.counter || "1") - 2;
                doClick(imageDisplay);
                break;
            }
          }

          document.body.addEventListener('keydown', keyPressed);
        </script>
      </body>
    </html>
  HTML

  File.write(File.join(root_path, "screenshots.html"), report_html)
end

def sync_ios_screenshots_from_snapshot!(raw_root:, structured_root:, clear_previous: true)
  raw_screenshots = Dir[File.join(raw_root, "*", "*.png")]
  UI.user_error!("No iOS screenshots were generated in #{raw_root}") if raw_screenshots.empty?

  clear_ios_structured_screenshots!(structured_root) if clear_previous

  raw_screenshots.each do |file_path|
    locale = File.basename(File.dirname(file_path))
    target_directory = File.join(structured_root, locale, "images", IOS_SCREENSHOT_DEVICE_DIR)
    FileUtils.mkdir_p(target_directory)
    FileUtils.cp(file_path, File.join(target_directory, File.basename(file_path)))
  end

  generate_ios_screenshot_report!(structured_root)
end

def prepare_ios_screenshots_for_deliver(source_root)
  structured_screenshots = ios_collect_structured_screenshots(source_root)
  return source_root if structured_screenshots.empty?

  FileUtils.rm_rf(IOS_SCREENSHOTS_UPLOAD_DIRECTORY)
  FileUtils.mkdir_p(IOS_SCREENSHOTS_UPLOAD_DIRECTORY)

  structured_screenshots.each do |locale, files|
    deliver_locale = IOS_DELIVER_LOCALE_ALIASES.fetch(locale, locale)
    locale_directory = File.join(IOS_SCREENSHOTS_UPLOAD_DIRECTORY, deliver_locale)
    FileUtils.mkdir_p(locale_directory)

    files.each do |file_path|
      FileUtils.cp(file_path, File.join(locale_directory, File.basename(file_path)))
    end
  end

  IOS_SCREENSHOTS_UPLOAD_DIRECTORY
end

def prepare_ios_metadata_for_deliver(source_root)
  FileUtils.rm_rf(IOS_METADATA_UPLOAD_DIRECTORY)
  FileUtils.mkdir_p(IOS_METADATA_UPLOAD_DIRECTORY)

  Dir.children(source_root).sort.each do |locale|
    locale_source = File.join(source_root, locale)
    next unless File.directory?(locale_source)
    next if locale == "changelogs"

    deliver_locale = IOS_DELIVER_LOCALE_ALIASES.fetch(locale, locale)
    locale_target = File.join(IOS_METADATA_UPLOAD_DIRECTORY, deliver_locale)
    copied_any_metadata_file = false

    Dir[File.join(locale_source, "**", "*")].sort.each do |file_path|
      next unless File.file?(file_path)

      relative_path = file_path.delete_prefix("#{locale_source}/")
      next if relative_path.start_with?("images/")

      target_path = File.join(locale_target, relative_path)
      FileUtils.mkdir_p(File.dirname(target_path))
      FileUtils.cp(file_path, target_path)
      copied_any_metadata_file = true
    end

    FileUtils.rm_rf(locale_target) unless copied_any_metadata_file
  end

  IOS_METADATA_UPLOAD_DIRECTORY
end

def directory_contains_files?(root_path)
  Dir.exist?(root_path) && !Dir[File.join(root_path, "**", "*")].grep(File.method(:file?)).empty?
end

def default_ios_ipa_path
  ipa_paths = Dir[File.join(IOS_IPA_DIRECTORY, "*.ipa")].sort
  UI.user_error!("Missing iOS IPA in #{IOS_IPA_DIRECTORY}. Run the iOS build lane first.") if ipa_paths.empty?

  ipa_paths.last
end

def ios_changelog_path_for(build_number)
  specific_path = File.join(IOS_CHANGELOGS_DIRECTORY, "#{build_number}.txt")
  return specific_path if File.exist?(specific_path)

  default_path = File.join(IOS_CHANGELOGS_DIRECTORY, "default.txt")
  return default_path if File.exist?(default_path)

  nil
end

def resolved_ios_changelog(options, build_number)
  inline_changelog = options[:changelog].to_s.strip
  return inline_changelog unless inline_changelog.empty?

  explicit_path = options[:changelog_path].to_s.strip
  if !explicit_path.empty?
    changelog_path = File.expand_path(explicit_path, PROJECT_ROOT)
    UI.user_error!("Missing iOS changelog file: #{changelog_path}") unless File.exist?(changelog_path)

    changelog_contents = File.read(changelog_path).strip
    UI.user_error!("iOS changelog file is empty: #{changelog_path}") if changelog_contents.empty?

    return changelog_contents
  end

  changelog_path = ios_changelog_path_for(build_number)
  return nil if changelog_path.nil?

  changelog_contents = File.read(changelog_path).strip
  return nil if changelog_contents.empty?

  changelog_contents
end

platform :android do
  desc "Check that Play Store release prerequisites are available"
  lane :check_play_store_setup do |options|
    UI.user_error!(
      "Missing Play service account JSON: #{PLAY_SERVICE_ACCOUNT_JSON}",
    ) unless File.exist?(PLAY_SERVICE_ACCOUNT_JSON)

    next unless options[:require_signing]

    has_key_properties = File.exist?(ANDROID_KEY_PROPERTIES)
    has_env_signing = %w[
      ANDROID_STORE_FILE
      ANDROID_STORE_PASSWORD
      ANDROID_KEY_ALIAS
      ANDROID_KEY_PASSWORD
    ].all? { |key| ENV[key].to_s.strip != "" }

    unless has_key_properties || has_env_signing
      UI.user_error!(
        "Missing Android release signing config. Add android/key.properties or export the ANDROID_* signing variables.",
      )
    end
  end

  desc "Upload listing metadata, store images, and screenshots"
  lane :metadata do |options|
    check_play_store_setup(require_signing: false)

    metadata_upload_options = {
      version_code: options[:version_code] || current_version_code,
      skip_upload_aab: true,
      skip_upload_apk: true,
      skip_upload_metadata: false,
      skip_upload_images: false,
      skip_upload_screenshots: false,
      skip_upload_changelogs: false,
    }
    metadata_upload_options[:track] = options[:track] if options[:track]
    metadata_upload_options[:release_status] = options[:release_status] if options[:release_status]

    upload_to_play_store(**metadata_upload_options)
  end

  desc "Upload only Play Store images and screenshots"
  lane :assets do
    check_play_store_setup(require_signing: false)

    upload_to_play_store(
      skip_upload_aab: true,
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_images: false,
      skip_upload_screenshots: false,
      skip_upload_changelogs: true,
    )
  end

  desc "Build a release app bundle and upload only the binary to the internal track"
  lane :binary do |options|
    check_play_store_setup(require_signing: true)
    build_release_bundle

    upload_to_play_store(
      track: options[:track] || "internal",
      release_status: options[:release_status] || "draft",
      version_code: options[:version_code] || current_version_code,
      aab: options[:aab] || "build/app/outputs/bundle/release/app-release.aab",
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
  end

  desc "Build a release app bundle and upload it with metadata/assets to the internal track"
  lane :internal do |options|
    check_play_store_setup(require_signing: true)
    build_release_bundle

    upload_to_play_store(
      track: options[:track] || "internal",
      release_status: options[:release_status] || "draft",
      version_code: options[:version_code] || current_version_code,
      aab: options[:aab] || "build/app/outputs/bundle/release/app-release.aab",
      skip_upload_metadata: false,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
  end

  desc "Validate a Play upload without publishing it"
  lane :validate do |options|
    check_play_store_setup(require_signing: true)
    build_release_bundle

    upload_to_play_store(
      track: options[:track] || "internal",
      release_status: options[:release_status] || "draft",
      version_code: options[:version_code] || current_version_code,
      aab: options[:aab] || "build/app/outputs/bundle/release/app-release.aab",
      skip_upload_metadata: false,
      skip_upload_images: false,
      skip_upload_screenshots: false,
      validate_only: true,
    )
  end

  desc "Build screenshot artifacts and capture Play Store screenshots with Screengrab"
  lane :screenshots do |options|
    connected_devices = android_connected_devices
    if connected_devices.empty?
      UI.user_error!(
        "No connected Android devices or emulators found. Start the phone emulator and any tablet emulators before running 'fastlane android screenshots'.",
      )
    end

    screenshot_targets = android_screenshot_targets(options, connected_devices)

    gradle(
      project_dir: "android",
      task: "app:assembleDebug",
    )

    gradle(
      project_dir: "android",
      task: "app:assembleAndroidTest",
    )

    screenshot_targets.each_with_index do |target, index|
      UI.message(
        "Capturing #{target[:description]} screenshots#{target[:specific_device] ? " on #{target[:device_selector]} (#{target[:specific_device]})" : ""}.",
      )

      screengrab_options = {
        device_type: target[:device_type],
        clear_previous_screenshots: index.zero?,
        skip_open_summary: index < screenshot_targets.length - 1,
        reinstall_app: true,
      }
      screengrab_options[:specific_device] = target[:specific_device] unless target[:specific_device].nil?

      screengrab(**screengrab_options)
    end
  end

  lane :generate_screenshots do
    screenshots
  end

  private_lane :build_release_bundle do
    Dir.chdir(PROJECT_ROOT) do
      sh("flutter build appbundle --release")
    end
  end
end

platform :ios do
  desc "Check that App Store Connect/TestFlight release prerequisites are available"
  lane :check_app_store_setup do
    configure_ios_build_environment
    api_key_options = app_store_connect_api_key_options

    UI.user_error!("Missing iOS workspace: #{IOS_WORKSPACE}") unless File.exist?(IOS_WORKSPACE)

    if api_key_options.nil?
      UI.user_error!(
        "Missing App Store Connect API key metadata. Provide APP_STORE_CONNECT_KEY_ID and APP_STORE_CONNECT_ISSUER_ID via environment variables or #{APP_STORE_CONNECT_API_KEY_CONFIG}. The private key can come from APP_STORE_CONNECT_API_KEY_PATH, APP_STORE_CONNECT_API_KEY_CONTENT, APP_STORE_CONNECT_API_KEY_BASE64, or the default fastlane/app-store-connect-api-key.p8 file.",
      )
    end

    if api_key_options[:key_filepath] && !File.exist?(api_key_options[:key_filepath])
      UI.user_error!("Missing App Store Connect API key file: #{api_key_options[:key_filepath]}")
    end
  end

  desc "Build a signed iOS IPA for App Store Connect/TestFlight"
  lane :binary do |options|
    check_app_store_setup
    build_release_ipa(options)
  end

  desc "Capture App Store screenshots with snapshot"
  lane :screenshots do |options|
    configure_ios_build_environment
    ensure_ios_screenshot_setup!(options)

    raw_output_directory = File.expand_path(options[:output_directory] || IOS_SNAPSHOT_RAW_DIRECTORY, PROJECT_ROOT)

    snapshot_options = {
      workspace: IOS_WORKSPACE,
      scheme: options[:scheme] || ENV["IOS_SNAPSHOT_SCHEME"] || "RunnerScreenshots",
      output_directory: raw_output_directory,
      clear_previous_screenshots: options.key?(:clear_previous_screenshots) ? options[:clear_previous_screenshots] : true,
      reinstall_app: options.key?(:reinstall_app) ? options[:reinstall_app] : true,
      erase_simulator: options.key?(:erase_simulator) ? options[:erase_simulator] : true,
      stop_after_first_error: options.key?(:stop_after_first_error) ? options[:stop_after_first_error] : true,
    }
    snapshot_options[:devices] = Array(options[:devices]) if options[:devices]
    snapshot_options[:languages] = Array(options[:languages]) if options[:languages]
    snapshot_options[:ios_version] = options[:ios_version] if options[:ios_version]

    snapshot(**snapshot_options)

    sync_ios_screenshots_from_snapshot!(
      raw_root: raw_output_directory,
      structured_root: IOS_SCREENSHOTS_DIRECTORY,
      clear_previous: snapshot_options[:clear_previous_screenshots],
    )
  end

  desc "Upload App Store metadata and screenshots without uploading a new binary"
  lane :metadata do |options|
    check_app_store_setup
    ensure_ios_metadata_inputs!(options)

    api_key = app_store_connect_api_key(**app_store_connect_api_key_options)
    metadata_path = File.expand_path(options[:metadata_path] || IOS_METADATA_DIRECTORY, PROJECT_ROOT)
    screenshots_path = File.expand_path(options[:screenshots_path] || IOS_SCREENSHOTS_DIRECTORY, PROJECT_ROOT)
    prepared_metadata_path = prepare_ios_metadata_for_deliver(metadata_path)
    prepared_screenshots_path = prepare_ios_screenshots_for_deliver(screenshots_path)
    skip_metadata = options.key?(:skip_metadata) ? options[:skip_metadata] : !directory_contains_files?(prepared_metadata_path)

    UI.message("No iOS metadata files detected. Skipping metadata upload and uploading screenshots only.") if skip_metadata

    deliver_options = {
      api_key: api_key,
      app_identifier: IOS_APP_IDENTIFIER,
      metadata_path: prepared_metadata_path,
      screenshots_path: prepared_screenshots_path,
      skip_binary_upload: true,
      skip_metadata: skip_metadata,
      skip_screenshots: options.key?(:skip_screenshots) ? options[:skip_screenshots] : false,
      overwrite_screenshots: options.key?(:overwrite_screenshots) ? options[:overwrite_screenshots] : true,
      skip_app_version_update: options.key?(:skip_app_version_update) ? options[:skip_app_version_update] : true,
      submit_for_review: false,
      automatic_release: false,
      run_precheck_before_submit: false,
      force: true,
    }

    deliver(**deliver_options)
  end

  desc "Build a signed iOS IPA and upload it to TestFlight for internal testing"
  lane :internal do |options|
    check_app_store_setup

    api_key = app_store_connect_api_key(**app_store_connect_api_key_options)
    ipa_path = options[:ipa].to_s.strip
    build_number = options[:build_number] || current_version_code

    if ipa_path.empty?
      build_release_ipa(options)
      ipa_path = default_ios_ipa_path
    end

    upload_options = {
      api_key: api_key,
      ipa: ipa_path,
      app_identifier: IOS_APP_IDENTIFIER,
      skip_waiting_for_build_processing: options.key?(:skip_waiting_for_build_processing) ? options[:skip_waiting_for_build_processing] : true,
      distribute_external: false,
      notify_external_testers: false,
    }
    changelog = resolved_ios_changelog(options, build_number)
    upload_options[:changelog] = changelog unless changelog.nil?
    upload_options[:groups] = Array(options[:groups]) if options[:groups]

    upload_to_testflight(**upload_options)
  end

  private_lane :build_release_ipa do |options|
    configure_ios_build_environment
    export_method = options[:export_method] || "app-store"
    build_name = options[:build_name] || current_version_name
    build_number = options[:build_number] || current_version_code

    build_args = [
      "flutter",
      "build",
      "ipa",
      "--release",
      "--export-method=#{export_method}",
      "--build-name=#{build_name}",
      "--build-number=#{build_number}",
    ]

    with_clean_ios_shell_environment do
      verify_cocoapods_available
      Dir.chdir(PROJECT_ROOT) do
        sh(build_args.shelljoin)
      end
    end
  end
end